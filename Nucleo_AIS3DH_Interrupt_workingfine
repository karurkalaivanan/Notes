/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_USART2_UART_Init();
  MX_SPI1_Init();
  /* USER CODE BEGIN 2 */
  char msg[64];
  uint8_t whoami;

  HAL_GPIO_WritePin(LIS3DH_CS_PORT, LIS3DH_CS_PIN, GPIO_PIN_SET);
  HAL_Delay(100);

  whoami = LIS3DH_ReadReg(WHO_AM_I_REG);
  sprintf(msg, "WHO_AM_I = 0x%02X\r\n", whoami);
  HAL_UART_Transmit(&huart2, (uint8_t*)msg, strlen(msg), HAL_MAX_DELAY);

  if (LIS3DH_Init())
  {
    uint8_t ok[] = "LIS3DH Detected & Initialized!\r\n";
    HAL_UART_Transmit(&huart2, ok, sizeof(ok) - 1, HAL_MAX_DELAY);
  }
  else
  {
    uint8_t fail[] = "LIS3DH Not Detected!\r\n";
    HAL_UART_Transmit(&huart2, fail, sizeof(fail) - 1, HAL_MAX_DELAY);
  }

  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
    if (accel_data_ready)
    {
      accel_data_ready = 0;

      if ((LIS3DH_ReadReg(INT1_SRC) & 0x40U) == 0U)
      {
        continue;
      }

      LIS3DH_ReadXYZ(&X, &Y, &Z);

      if (xyz_valid)
      {
        int16_t dx = X - last_X;
        int16_t dy = Y - last_Y;
        int16_t dz = Z - last_Z;

        if (dx < 0) dx = -dx;
        if (dy < 0) dy = -dy;
        if (dz < 0) dz = -dz;

        if ((dx <= MOTION_DELTA_COUNTS) &&
            (dy <= MOTION_DELTA_COUNTS) &&
            (dz <= MOTION_DELTA_COUNTS))
        {
          continue;
        }
      }

      last_X = X;
      last_Y = Y;
      last_Z = Z;
      xyz_valid = 1;

      char buf[64];
      sprintf(buf, "X=%d  Y=%d  Z=%d\r\n", X, Y, Z);
      HAL_UART_Transmit(&huart2, (uint8_t*)buf, strlen(buf), HAL_MAX_DELAY);
    }
  }
  /* USER CODE END 3 */
}

