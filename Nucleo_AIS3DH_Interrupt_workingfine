uint8_t LIS3DH_ReadReg(uint8_t reg)
{
  uint8_t tx[2];
  uint8_t rx[2];

  tx[0] = reg | 0x80;
  tx[1] = 0x00;

  LIS3DH_CS_LOW();
  HAL_SPI_TransmitReceive(&hspi1, tx, rx, 2, 100);
  LIS3DH_CS_HIGH();

  return rx[1];
}

void LIS3DH_WriteReg(uint8_t reg, uint8_t data)
{
  uint8_t tx[2];

  tx[0] = reg & 0x7F;
  tx[1] = data;

  LIS3DH_CS_LOW();
  HAL_SPI_Transmit(&hspi1, tx, 2, 100);
  LIS3DH_CS_HIGH();
}

uint8_t LIS3DH_Init(void)
{
  uint8_t id = LIS3DH_ReadReg(WHO_AM_I_REG);

  if (id != 0x33)
    return 0;

  LIS3DH_WriteReg(CTRL_REG1, LIS3DH_ODR | 0x07);         // ODR + all axes enabled
  LIS3DH_WriteReg(CTRL_REG2, 0x01);                       // High-pass filter to INT1 generator
  LIS3DH_WriteReg(CTRL_REG4, 0x88);                       // BDU + high-resolution, +-2g
  LIS3DH_WriteReg(INT1_THS, (uint8_t)INT1_THS_VALUE);     // Closest hardware threshold to 10mg
  LIS3DH_WriteReg(INT1_DURATION, 0x03);                   // Event must persist ~30ms at 100Hz
  LIS3DH_WriteReg(INT1_CFG, 0x2A);                        // Interrupt on positive change on X/Y/Z
  LIS3DH_WriteReg(CTRL_REG5, 0x08);                       // Latch INT1 until INT1_SRC read
  LIS3DH_WriteReg(CTRL_REG3, 0x40);                       // Route INT1 generator to INT1 pin

  (void)LIS3DH_ReadReg(REFERENCE_REG);                    // Set HP filter reference baseline
  (void)LIS3DH_ReadReg(INT1_SRC);                         // Clear pending latched interrupt

  return 1;
}

void LIS3DH_ReadXYZ(int16_t *x, int16_t *y, int16_t *z)
{
  uint8_t tx[7] = {0};
  uint8_t rx[7] = {0};

  tx[0] = 0x28 | 0x80 | 0x40;  // Read + Auto-Increment starting at OUT_X_L

  LIS3DH_CS_LOW();
  HAL_SPI_TransmitReceive(&hspi1, tx, rx, 7, 100);
  LIS3DH_CS_HIGH();

  *x = (int16_t)((rx[2] << 8) | rx[1]) >> 4;
  *y = (int16_t)((rx[4] << 8) | rx[3]) >> 4;
  *z = (int16_t)((rx[6] << 8) | rx[5]) >> 4;
}

void HAL_GPIO_EXTI_Rising_Callback(uint16_t GPIO_Pin)
{
  if (GPIO_Pin == GPIO_PIN_0)
  {
    accel_data_ready = 1;
  }
}

